# Copy to .env and fill in values (never commit .env):
#   cp .env.example .env
#
# The app loads .env automatically on startup (config.Load) when the file exists.
# Run from the repo root so .env is found, e.g.:
#   go run ./cmd/telegram

# --- App (all entrypoints) ---
LOG_LEVEL=info

# PostgreSQL (required for bot, migrate, cmd/credit)
DATABASE_URL=postgres://easyterms:easyterms@localhost:5432/easyterms?sslmode=disable

# --- Telegram bot (cmd/telegram) ---
TELEGRAM_BOT_TOKEN=

# --- LLM (OpenAI-compatible: OpenAI, OpenRouter, etc.) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER_LABEL=openai-compatible
