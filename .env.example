# Copy to .env and fill in values (never commit .env):
#   cp .env.example .env
#
# The app loads .env automatically on startup (config.Load) when the file exists.
# Run from the repo root so .env is found, e.g.:
#   go run ./cmd/telegram

# --- App (all entrypoints) ---
LOG_LEVEL=info

# PostgreSQL (required for bot, migrate, cmd/credit)
DATABASE_URL=postgres://easyterms:easyterms@localhost:5432/easyterms?sslmode=disable

# --- Telegram bot (cmd/telegram) ---
TELEGRAM_BOT_TOKEN=

# --- LLM (OpenAI-compatible HTTP API) ---
# Provider kind (only openai-compatible for now; same adapter for OpenAI, LM Studio, OpenRouter, …)
LLM_PROVIDER=openai-compatible

# Cloud OpenAI example:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_JSON_MODE=true
# LLM_PROVIDER_LABEL=openai

# Local LM Studio example (OpenAI-compatible server on your LAN):
# LLM_BASE_URL=http://100.64.0.7:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=qwen/qwen3.6-27b
# LLM_JSON_MODE=false
# LLM_PROVIDER_LABEL=lm-studio

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_JSON_MODE=true
LLM_PROVIDER_LABEL=openai-compatible
